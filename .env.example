# Copy this file to .env and fill in your values.
# The server loads these automatically on startup.

# ── Delivery eligibility ────────────────────────────────────────────────────

# Leave blank to use free OpenStreetMap mode (no key needed, less accurate).
# Set to your Google Maps API key for real driving distance + drive-time.
GOOGLE_MAPS_API_KEY=

# Full address of your restaurant (used as the "origin" for distance checks)
RESTAURANT_ADDRESS=Rotelli Pizza & Pasta, Boca Raton, FL 33434

# Lat/lng of your restaurant — only used when GOOGLE_MAPS_API_KEY is blank.
# Look up your exact coordinates at: https://www.latlong.net
RESTAURANT_LAT=26.3887
RESTAURANT_LNG=-80.1450

# Maximum driving distance for delivery (miles)
DELIVERY_RADIUS_MILES=6.0

# ── Order cart ───────────────────────────────────────────────────────────────

# Minimum food subtotal (in dollars) required to qualify for delivery
DELIVERY_MINIMUM=20.00

# Flat delivery fee added on top of food subtotal for delivery orders
DELIVERY_FEE=2.99

# ── Clover POS integration ────────────────────────────────────────────────────
# Phase 1 testing: use sandbox URL + a sandbox test merchant
# Phase 2 production: switch to https://api.clover.com + real merchant creds
#
# Leave CLOVER_MERCHANT_ID and CLOVER_API_TOKEN blank to run without Clover.
# Orders will still confirm locally — Clover push is skipped silently.

# Sandbox: https://sandbox.dev.clover.com
# Production: https://api.clover.com
CLOVER_API_BASE=https://sandbox.dev.clover.com

# Found in Clover Developer Dashboard → Your test merchant
CLOVER_MERCHANT_ID=

# REST API token from Clover Developer Dashboard → API Tokens
CLOVER_API_TOKEN=

# ── Database ─────────────────────────────────────────────────────────────────
# DB_PATH=restaurant.db   # default, override to change location
